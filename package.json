{
  "name": "PipelineCI",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@types/js-yaml": "^4.0.9",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.1",
    "pg": "^8.20.0"
  }
}
